# Copy this to your hosting platform/environment variables.
# Do not commit real secrets.

# Required. Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
LCT_SECRET_KEY=replace-with-long-random-secret

# Required on first run. This Google account becomes the first admin.
# No password is hardcoded in the app.
LCT_ADMIN_EMAIL=your-google-email@example.com
LCT_ADMIN_DISPLAY_NAME=Tyler Ledbetter

# Recommended for production behind HTTPS / Cloud Run / reverse proxy.
LCT_SECURE_COOKIES=false

# Optional local username/password login fallback.
# Leave disabled for Google-only login.
LOCAL_AUTH_ENABLED=false
LCT_ADMIN_USERNAME=
LCT_ADMIN_PASSWORD=

# Google OAuth / OpenID Connect
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback

# Security controls for Google login.
# If set, only this domain can use Google login, e.g. gmail.com or cobbk12.org.
ALLOWED_EMAIL_DOMAIN=

# Safer default: false. Users must exist first or match LCT_ADMIN_EMAIL.
GOOGLE_AUTO_CREATE_USERS=false
